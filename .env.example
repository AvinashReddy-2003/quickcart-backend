# --- App ---
NODE_ENV=development
PORT=3000

# --- Database (matches docker-compose.yml) ---
DATABASE_URL="postgresql://quickcart:quickcart@localhost:5432/quickcart?schema=public"

# --- Redis (OTP store, sessions, cache) ---
REDIS_URL="redis://localhost:6379"

# --- Auth / JWT ---
# Generate strong values for production: `openssl rand -base64 48`
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"

# --- OTP ---
# In development the OTP is returned in the API response instead of sending SMS.
OTP_TTL_SECONDS=300
