// QuickCart – unified catalog schema (multi-vertical super-app)
// One flexible product model serves every vertical:
//   FOOD    -> Zomato-style restaurants & dishes
//   GROCERY -> quick-commerce grocery stores & items
//   SHOP    -> Amazon-style shops & products
// Tables: users, stores, products, orders, order_items

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  VENDOR
  RIDER
  ADMIN
}

enum Vertical {
  FOOD
  GROCERY
  SHOP
}

enum OrderStatus {
  PLACED
  PREPARING
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

model User {
  id        String   @id @default(uuid())
  phone     String   @unique
  name      String?
  email     String?  @unique
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stores    Store[]   @relation("VendorStores")
  orders    Order[]
  addresses Address[]

  @@map("users")
}

model Address {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String? // e.g. "Home", "Work"
  line1     String
  line2     String?
  city      String
  pincode   String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@index([userId])
  @@map("addresses")
}

/// A merchant in any vertical: a restaurant, a grocery store, or a shop.
model Store {
  id          String   @id @default(uuid())
  name        String
  vertical    Vertical @default(FOOD)
  description String?
  address     String?
  // Food-specific hints (null/ignored for GROCERY & SHOP):
  cuisine     String?
  isVeg       Boolean  @default(false)
  imageUrl    String?
  rating      Float?
  isActive    Boolean  @default(true)
  vendorId    String?
  vendor      User?    @relation("VendorStores", fields: [vendorId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products Product[]
  orders   Order[]

  @@index([vertical])
  @@map("stores")
}

/// A sellable item in any vertical: a dish, a grocery SKU, or a product.
model Product {
  id          String   @id @default(uuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name        String
  description String?
  price       Decimal  @db.Decimal(10, 2)
  category    String?
  imageUrl    String?
  inStock     Boolean  @default(true)
  // Food-only attribute; null for non-food products.
  isVeg       Boolean?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems OrderItem[]

  @@index([storeId])
  @@map("products")
}

model Order {
  id            String        @id @default(uuid())
  customerId    String
  customer      User          @relation(fields: [customerId], references: [id])
  storeId       String
  store         Store         @relation(fields: [storeId], references: [id])
  addressId     String?
  address       Address?      @relation(fields: [addressId], references: [id])
  status        OrderStatus   @default(PLACED)
  paymentStatus PaymentStatus @default(PENDING)
  subtotal      Decimal       @default(0) @db.Decimal(10, 2)
  deliveryFee   Decimal       @default(0) @db.Decimal(10, 2)
  discount      Decimal       @default(0) @db.Decimal(10, 2)
  total         Decimal       @default(0) @db.Decimal(10, 2)
  couponCode    String?
  // Payment provider references (Razorpay, or mock in dev).
  paymentOrderId String?
  paymentId      String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  items OrderItem[]

  @@index([customerId])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)

  @@map("order_items")
}
